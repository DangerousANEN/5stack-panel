# Each domain must be unique for routing purposes

# example: 5stack.gg
WEB_DOMAIN=

# example: ws.5stack.gg
WS_DOMAIN=

# example: api.5stack.gg
API_DOMAIN=

# example: tv.5stack.gg
RELAY_DOMAIN=

# example: demos.5stack.gg
DEMOS_DOMAIN=

# example: hls.5stack.gg
GAME_STREAM_DOMAIN=

# example: hud.5stack.gg
# F2: public OBS-friendly HUD stream (reverse-proxied to api:5585/hud-stream).
HUD_DOMAIN=

# Optional override for the spectator streamer pod image. Leave blank to use
# the upstream default (ghcr.io/5stackgg/game-streamer:latest). Set to your
# fork (e.g. ghcr.io/<owner>/game-streamer:latest) when running custom builds.
GAME_STREAMER_IMAGE=

# Optional override for the match-server (cs2 / csgo dedicated server) pod
# image. Leave blank to use the upstream default
# (ghcr.io/5stackgg/game-server:latest). Set to your fork
# (e.g. ghcr.io/<owner>/game-server:latest) when running custom builds.
# Read by api as `process.env.SERVER_IMAGE` (see api/src/configs/game-servers.ts).
SERVER_IMAGE=

# example: hello@example.com
MAIL_FROM=

TAILSCALE_NODE_IP=

TAILSCALE_NET_NAME=

TAILSCALE_CLIENT_ID=
